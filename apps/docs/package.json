{
  "name": "@vbot/docs",
  "version": "0.0.4",
  "private": true,
  "scripts": {
    "build": "next build",
    "sync:sources": "bash scripts/sync-sources.sh",
    "generate:api-reference": "python3 scripts/generate-api-reference.py",
    "update:docs-sources": "bash scripts/sync-sources.sh && python3 scripts/generate-api-reference.py",
    "dev": "next dev -p 3001",
    "start": "next start -p 3001",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },

  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@vercel/microfrontends": "latest",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.3",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  }
}